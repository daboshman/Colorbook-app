rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // /images/**: public reads, authenticated writes only
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
